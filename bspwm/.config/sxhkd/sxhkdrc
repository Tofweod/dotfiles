#
# wm independent hotkeys
#

# show help
super + F1
  $HOME/.config/sxhkd/scripts/show_help.sh

# actions
# toggle scratchpad
super + grave
  $HOME/.config/sxhkd/scripts/scratchpad.sh

# rofi start application
super + s
  rofi -show drun -show-icons

# screenshot
super + shift + s
  scrot -s ~/Pictures/screenshots/%Y-%m-%d-%T.png

# open local floating terminal
super + ctrl + n
  alacritty -t term-global --class floatingTerminal

# terminal emulator
super + Return
	alacritty

# program launcher
super + u
  dmen_run

# lock screen
alt + l
  lock

# translate selected text by ollama
alt + e
  $HOME/.local/bin/trans_selected

# turn on powermenu
super + ctrl + Escape
  $HOME/.config/polybar/colorblocks/scripts/powermenu.sh

# make sxhkd reload its configuration files:
super + Escape
	pkill -USR1 -x sxhkd

#
# bspwm hotkeys
#

# quit/restart bspwm
super + alt + {q,r}
	bspc {quit,wm -r}

# kill
super + shift + ctrl + q
	bspc node -k

# close or hidden
super + shift + q
  $HOME/.config/sxhkd/scripts/close_or_hidden.sh

# alternate between the tiled and monocle layout
super +shift + space
	bspc desktop -l next

# send the newest marked node to the newest preselected node
super + y
	bspc node newest.marked.local -n newest.!automatic.local

# swap the current node and the biggest window
super + shift + Return
	bspc node -s biggest.local.window

# rotate the root of current desktop
super + shift + r
    bspc node @/ -R 90

# rotate the parent of current focused
super + r
    bspc node @parent -R 90

# Move mouse to the targeted monitor
super + ctrl + {Left,Right,Up,Down}
    bspc monitor -f {west,east,north,south}


#
# state/flags
#

# targetkey
super + c
  $HOME/.config/sxhkd/scripts/jump_or_run.sh $TOFWEOD_BROWSER_DESKTOP firefox
super + shift + c
	bspc node -d $TOFWEOD_BROWSER_DESKTOP --follow

super + p
  $HOME/.config/sxhkd/scripts/jump_or_run.sh $TOFWEOD_MUSIC_PLAYER_DESKTOP /opt/SPlayer/SPlayer
super + shift + p
	bspc node -d $TOFWEOD_MUSIC_PLAYER_DESKTOP --follow

super + 0
  $HOME/.config/sxhkd/scripts/jump_or_run.sh $TOFWEOD_TMUX_DESKTOP alacritty -t terminal -e tmux new -A -s terminal-tag
super + shift + 0
	bspc node -d $TOFWEOD_TMUX_DESKTOP --follow

super + m
  $HOME/.config/sxhkd/scripts/jump_or_run.sh $TOFWEOD_MAIL_DESKTOP thunderbird
super + shift + m 
	bspc node -d $TOFWEOD_MAIL_DESKTOP --follow


# toggle bar
super + b
  $HOME/.config/sxhkd/scripts/polybar_toggle.sh

# hide current window
super + d
    bspc node -g hidden=on

# restore hidden windows in current desktop
super + shift + d
  $HOME/.config/sxhkd/scripts/unhide_cur_desktop_window.sh

# select window, used in monocle mode or when there are floating winodws
super + w 
  $HOME/.config/sxhkd/scripts/select_cur_desktop_window.sh

# select all windows, including hidden ones
super + ctrl + w
  $HOME/.config/sxhkd/scripts/all_windows.sh

# set the window state
super + {space,shift + t,f,z}
	bspc node -t {tiled,pseudo_tiled,floating,fullscreen}


# set the node flags
super + ctrl + {m,x,y,z}
	bspc node -g {marked,locked,sticky,private}

#
# focus/swap
#

# focus the node in the given direction
super + {_,shift + }{h,j,k,l}
	bspc node -{f,s} {west,south,north,east}


# focus the next/previous window in the current desktop
super + {_,shift + }n
	bspc node -f {next,prev}.local.!hidden.window

# focus the next/previous desktop in the current monitor
super + bracket{left,right}
	bspc desktop -f {prev,next}.local

# focus the last desktop
super + Tab
	bspc desktop -f last

# focus the older or newer node in the focus history
super + {o,i}
	bspc wm -h off; \
	bspc node {older,newer} -f; \
	bspc wm -h on

# focus or send to the given desktop
super + {1-9}
	bspc desktop -f '{1-9}'

super + shift + {1-9}
	bspc node -d '{1-9}' --follow

super + g
  bspc desktop -f $TOFWEOD_GAME_DESKTOP
super + shift + g
  bspc node -d $TOFWEOD_GAME_DESKTOP --follow

#
# preselect
#

# preselect the direction
super + ctrl + {h,j,k,l}
	bspc node -p {west,south,north,east}

# preselect the ratio
super + ctrl + {1-9}
	bspc node -o 0.{1-9}

# cancel the preselection for the focused node
super + ctrl + space
	bspc node -p cancel

# cancel the preselection for the focused desktop
super + ctrl + shift + space
	bspc query -N -d | xargs -I id -n 1 bspc node id -p cancel

#
# move/resize
#

# expand a window by moving one of its side outward
super + alt + {h,j,k,l}
	bspc node -z {left -20 0,bottom 0 20,top 0 -20,right 20 0}

# contract a window by moving one of its side inward
super + alt + shift + {h,j,k,l}
	bspc node -z {right -20 0,top 0 20,bottom 0 -20,left 20 0}

# move a floating window
super + {Left,Down,Up,Right}
	bspc node -v {-20 0,0 20,0 -20,20 0}

