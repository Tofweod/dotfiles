#!/bin/bash

UUID="16C0-79A9"
MOUNT_POINT="/mnt/res"
FS_TYPE="exfat"

if [ ! -d "$MOUNT_POINT" ]; then
  echo "挂载点 $MOUNT_POINT 不存在，正在创建..."
  sudo mkdir -p "$MOUNT_POINT"
fi

echo "正在挂载 Res 分区..."
echo $GID
sudo mount -t $FS_TYPE -o uid=$(id -u),gid=$(id -g) UUID=$UUID "$MOUNT_POINT"

if [ $? -ne 0 ]; then
  exit 1
fi

if mountpoint -q "$MOUNT_POINT"; then
  echo "挂载成功！分区已挂载到 $MOUNT_POINT"
else
  echo "挂载失败，请检查分区 UUID 或 ntfs-3g 是否安装"
fi
