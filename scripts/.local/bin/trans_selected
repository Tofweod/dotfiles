#!/bin/bash

HOST=127.0.0.1
PORT=11434

timeout=10000

MODEL="translategemma-4b-it.Q8_0.gguf"

model_file() {
  rootpath="$HOME/.cache/huggingface/hub/models--mradermacher--translategemma-4b-it-GGUF"
  hash="$(cat $rootpath/refs/main)"
  echo "$rootpath/snapshots/$hash/$MODEL"
}

start_server() {
  modelpath=$(model_file)
  llama-server --port $PORT \
    -m "$modelpath" \
    --no-jinja \
    --chat-template chatml \
    -t 8 \
    -ngl auto \
    -c 4096 \
    --temp 0.1 >/dev/null 2>&1 &
}

is_server_running() {
  lsof -i :"$PORT" >/dev/null 2>&1
}

start_model_ifneed() {
  if ! is_server_running; then
    dunstify "start translate server..."
    start_server
    sleep 3
  fi
}

start_model_ifneed

TEXT=$(xclip -selection primary -t UTF8_STRING -o)
if [ -z "$TEXT" ]; then
  notify-send "have not select text yet."
  exit 1
fi

prompt="You are a professional English (en) to Chinese (zh-Hans) translator. Your goal is to accurately convey the meaning and nuances of the original English text while adhering to Chinese grammar, vocabulary, and cultural sensitivities.
Produce only the Chinese translation, without any additional explanations or commentary. Please translate the following English text into Chinese:\n\n$TEXT"

json=$(jq -n --arg model "$MODEL" --arg msg "$prompt" \
  '{model: $model, messages: [{role: "user", content: $msg}]}')

response=$(curl -s -X POST http://$HOST:$PORT/v1/chat/completions \
  -H "Content-Type: application/json" \
  -d "$json" | jq -r '.choices[0].message.content')

dunstify "translate result is" "$response" -t $timeout
