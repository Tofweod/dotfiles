#! /bin/bash

# update change to relavant apps

# btop
cp $HOME/.cache/wal/btop.theme $HOME/.config/btop/themes/wal.theme
pkill -x btop >/dev/null

# cava
pkill -x cava >/dev/null

# bspwm
bspc wm -r

# alacritty
pywal2alacritty

# brave, need to manually restart
pywal2chromium

# telegram
# walogram

# yazi
cp $HOME/.cache/wal/yazi-flavor.toml $HOME/.config/yazi/flavors/wal.yazi/flavor.toml
